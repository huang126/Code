import random
import sys
import hashlib


# ==========================================
# 1. 基础数学工具
# ==========================================

def egcd(a, b):
    """扩展欧几里得算法 (迭代版)"""
    if a == 0:
        return (b, 0, 1)
    else:
        old_s, s = 1, 0
        old_t, t = 0, 1
        old_r, r = a, b

        while r != 0:
            quotient = old_r // r
            old_r, r = r, old_r - quotient * r
            old_s, s = s, old_s - quotient * s
            old_t, t = t, old_t - quotient * t

        return (old_r, old_s, old_t)


def modinv(a, m):
    """求模逆"""
    g, x, y = egcd(a, m)
    if g != 1:
        # 在生成大素数时极小概率遇到，重新生成即可
        raise Exception('Modular inverse does not exist')
    else:
        return x % m


def L(u, n):
    """Paillier L函数"""
    return (u - 1) // n


def is_prime(n, k=40):
    """Miller-Rabin 素数检测"""
    if n == 2 or n == 3: return True
    if n % 2 == 0 or n < 2: return False
    r, d = 0, n - 1
    while d % 2 == 0:
        r += 1
        d //= 2
    for _ in range(k):
        a = random.randrange(2, n - 1)
        x = pow(a, d, n)
        if x == 1 or x == n - 1:
            continue
        for _ in range(r - 1):
            x = pow(x, 2, n)
            if x == n - 1:
                break
        else:
            return False
    return True


def generate_large_prime(bits):
    """生成指定位数的素数"""
    print(f"  -> 正在寻找 {bits} 位的素数...", end="", flush=True)
    while True:
        n = random.getrandbits(bits)
        # 确保最高位为1(保证长度)和最低位为1(保证奇数)
        n |= (1 << (bits - 1)) | 1
        if is_prime(n):
            print(" 找到!")
            return n


def generate_hash_int(shared_key_int, cid_str):
    """
    生成哈希值并转为整数
    公式: H( Key || CID )
    """
    # 将大整数密钥转换为字符串，与 CID 拼接
    data = f"{shared_key_int}{cid_str}".encode('utf-8')
    # 使用 SHA-256 生成摘要
    digest = hashlib.sha256(data).hexdigest()
    # 转换为整数
    return int(digest, 16)


